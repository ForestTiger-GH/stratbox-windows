{
  "contract_version": "1.0",
  "distribution_profile_ref": "profile.desktop_client",
  "product_identity": {
    "product_id": "stratbox-windows.desktop",
    "display_name": "Strategy Box",
    "product_version": "0.1.0",
    "vendor": "Strategy Box",
    "channel": "stable"
  },
  "primary_source": {
    "source_form": "runtime_snapshot",
    "entry_mode": "preset_locked",
    "fixed_locator": "https://github.com/ForestTiger-GH/stratbox-windows.git",
    "ref_kind": "branch",
    "ref": "main",
    "refresh_policy": "on_launch",
    "refresh_failure_policy": "use_local",
    "modified_checkout_policy": "recreate"
  },
  "package_composition": {
    "package_sources": [
      {
        "mount_id": "stratbox",
        "source_ref": "https://github.com/ForestTiger-GH/stratbox.git",
        "source_kind": "remote_repository",
        "display_name": "Strategy Box Core",
        "include_mode": "packaged_snapshot",
        "probe_policy": "skip_source_probe",
        "installation_recipe": {
          "mode": "pip",
          "target": ".",
          "editable": false,
          "extras": []
        }
      }
    ]
  },
  "install_context": {
    "mode": "machine_managed_install",
    "install_display_name": "Strategy Box",
    "allow_install_root_override": false,
    "package_root_policy": "platform_managed",
    "data_root_policy": "platform_managed",
    "show_advanced_options": false
  },
  "shell": {
    "boot_surface": {
      "profile_id": "mark_default"
    },
    "setup_surface": {
      "profile_id": "shell_setup_terminal",
      "requires_before_runtime": true,
      "allow_skip_when_ready": true
    },
    "post_setup_entry": {
      "profile_id": "direct_entry_surface",
      "visibility": "visible"
    }
  },
  "visibility_policy": {
    "show_source_step": false,
    "show_preview_step": false,
    "show_install_step": true,
    "show_review_step": true
  },
  "branding": {
    "branding_mode": "default",
    "display_name_override": "Strategy Box"
  },
  "shortcut_policy": {
    "desktop_shortcut": false,
    "start_menu_shortcut": true,
    "shortcut_target": "shell"
  },
  "feature_selection": {
    "enabled_features": [
      "desktop_surface",
      "runtime_snapshot",
      "source_refresh_on_launch",
      "package_refresh_on_launch",
      "artifacts"
    ],
    "disabled_features": [
      "remote_attach",
      "delegated_jobs",
      "published_host"
    ],
    "visible_sectors": [
      "runtime",
      "workspace",
      "artifacts"
    ],
    "hidden_sectors": [
      "remote",
      "host"
    ]
  },
  "first_run": {
    "mode": "guided_setup",
    "requires_review_before_launch": true,
    "remember_user_choice": false,
    "auto_continue_when_ready": false,
    "open_shell_after_first_setup": false,
    "allow_skip_when_prepared": true
  },
  "update_policy": {
    "source_refresh": "on_launch",
    "package_refresh": "on_launch",
    "release_update": "manual",
    "channel": "embedded_release",
    "rollback_policy": "disallow",
    "failure_policy": "use_local",
    "staged_rollout": false
  },
  "metadata": {
    "product_kind": "desktop_analytics_app",
    "default_off_policy": true,
    "primary_source_mode": "preset_locked_runtime_snapshot",
    "primary_source_locator": "github_main_branch",
    "refresh_on_launch": true
  }
}
