{
  "contract_version": "1.0",
  "identity": {
    "world_id": "stratbox-windows",
    "display_name": "Strategy Box",
    "version": "0.1.0",
    "vendor": "Strategy Box",
    "description": "Strategy Box Windows desktop surface for AppDock-managed analytical work.",
    "display_category": "analytics_desktop"
  },
  "default_surface_id": "stratbox_windows.desktop",
  "surfaces": [
    {
      "surface_id": "stratbox_windows.desktop",
      "display_name": "Strategy Box",
      "surface_role": "interactive",
      "activation": {
        "kind": "python_module",
        "target": "stratbox_windows.adapters.appdock.entry",
        "args": [],
        "cwd_policy": {
          "mode": "source_root"
        },
        "env_policy": {
          "mode": "appdock_activation"
        },
        "diagnostics": {
          "strategy": "flag",
          "flag": "--diagnose",
          "timeout_seconds": 30
        },
        "launch_mode": "foreground",
        "locality": "local",
        "platform_constraints": {
          "node_platforms": [
            "windows_desktop_node"
          ],
          "client_platforms": [
            "desktop"
          ]
        },
        "metadata": {
          "ui": "primary"
        }
      },
      "entry_view": "scenario_chat",
      "declared_views": [
        "scenario_chat",
        "workspace",
        "atomic_scenarios",
        "scenario_blocks",
        "background_processes",
        "participants",
        "assignments",
        "logs",
        "artifacts",
        "parameters",
        "node_overview",
        "diagnostics",
        "settings"
      ],
      "compatible_modes": [
        "local"
      ],
      "required_capabilities": [
        "runtime.activate"
      ],
      "minimum_node_features": [
        "workspace_context",
        "health_snapshot"
      ],
      "supports_resume": true,
      "supports_artifacts": true,
      "supports_remote_attach": false,
      "supports_presence": true,
      "supports_delegated_jobs": false,
      "metadata": {
        "product": "Strategy Box",
        "ui_kind": "desktop_scenario_workspace",
        "route_groups_visible_in_app": [
          "scenarios",
          "workspace",
          "artifacts",
          "logs",
          "node",
          "diagnostics",
          "background",
          "participants",
          "assignments"
        ],
        "right_inspector": "case_aware_drawer",
        "ui_model": "scenario_first_operational_workspace",
        "history_model": "case_event_artifact_log",
        "collaboration_model": "presence_assignments"
      }
    }
  ],
  "profiles": {
    "world_profile": "desktop_analytical_world",
    "capability_profiles": [
      "desktop_analytical_world"
    ],
    "publication_profiles": [],
    "supported_node_modes": [
      "local"
    ]
  },
  "capabilities": {
    "supports_remote_attach": false,
    "supports_delegated_jobs": false,
    "supports_artifacts": true,
    "supports_resume": true,
    "supports_presence": true
  },
  "requirements": {
    "required_capabilities": [
      "runtime.activate"
    ],
    "minimum_node_features": [
      "workspace_context",
      "health_snapshot"
    ],
    "compatible_modes": [
      "local"
    ]
  },
  "storage": {
    "requests": {
      "install_root_system_dir": {
        "enabled": true,
        "directory_name": "stratbox-windows-system"
      }
    }
  },
  "metadata": {
    "description": "Strategy Box Windows scenario-first desktop app surface for AppDock world entry.",
    "ui_model": "scenario_first_operational_workspace",
    "right_inspector": "case_aware_drawer",
    "history_model": "case_event_artifact_log"
  }
}
